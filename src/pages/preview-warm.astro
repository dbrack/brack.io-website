---
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Projects from '../components/Projects.astro';
import VariantNote from '../components/VariantNote.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Dominik Brack | Preview B';
const description =
	'Preview of warmer social icon tint for Dominik Brack personal website.';
---

<BaseLayout title={title} description={description} bodyClass="variant-warm">
	<main class="home">
		<section class="intro" aria-labelledby="intro-title">
			<Header />
			<Navigation />
			<VariantNote label="Preview B: warmer, softer icon tint" />
		</section>

		<Projects />
	</main>
</BaseLayout>
