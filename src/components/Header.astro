---
import portrait from '../assets/portrait.jpeg';
---

<header class="hero">
	<img
		class="hero__portrait"
		src={portrait.src}
		width={portrait.width}
		height={portrait.height}
		alt="Portrait of Dominik Brack"
		loading="eager"
		decoding="async"
	/>

	<div class="hero__content">
		<h1 id="intro-title">Dominik Brack</h1>
		<p class="hero__tagline">
			Lifelong learner. Agile thinker. Passionate Product Person &amp;
			Software Engineer.
		</p>
	</div>
</header>
